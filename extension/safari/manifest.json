{
  "manifest_version": 3,
  "name": "HackOS Tracker",
  "version": "1.0.0",
  "description": "Hackathon tracker extension: extract details and save to your HackOS dashboard.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/*"],
  "action": {
    "default_title": "HackOS Tracker",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
